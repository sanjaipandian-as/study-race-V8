# StudyRace — Beispiel-Konfiguration
# Diese Datei nach .env kopieren und Werte anpassen.
#
# LOKAL (Windows):  einfach kopieren, DB_PASSWORD auf dein Postgres-Passwort
# SERVER (Netcup): wird automatisch von deploy/setup.sh erstellt

NODE_ENV=development
PORT=3000

# ─── Datenbank ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=studyrace
DB_USER=postgres
DB_PASSWORD=postgres

# ─── Auth ───
# WICHTIG: Vor Live-Betrieb durch einen zufälligen langen String ersetzen!
# Erzeugen mit:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Hinweis: Im Produktivbetrieb (NODE_ENV=production) startet der Server NICHT,
# wenn JWT_SECRET fehlt, zu kurz ist oder noch dieser Platzhalter ist.
JWT_SECRET=studyrace-lokal-dev-secret-aendern-vor-live

# ─── E-Mail (optional) ───
# Wenn diese gesetzt sind, sendet StudyRace echte E-Mails (Einladungen, Passwort-Reset).
# Wenn leer gelassen: E-Mails werden nur in der Server-Konsole geloggt (zum Testen ok).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=deine@email.de
# SMTP_PASSWORD=app-passwort
# SMTP_FROM=StudyRace <noreply@studyrace.de>
# BASE_URL=https://studyrace.de
